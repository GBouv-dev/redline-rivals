{% extends 'base.html.twig' %}

{% block title %}
    {{ isOwner ? 'Mon Profil' : (profileUser.username ?? profileUser.email|split('@')[0]) ~ ' — Profil' }} - Redline Rivals
{% endblock %}

{% block body %}

{# ══════════════════════════════════════════════════════════════ HERO ═══ #}
<section class="profile-hero">
    <div class="hero-scan-lines"></div>
    <div class="profile-hero-inner">

        {# Avatar #}
        <div class="avatar-wrapper" id="avatarWrapper">
            <div class="avatar-ring"></div>
            <div class="avatar-display" id="avatarDisplay">
                {{ profileUser.avatar ?? '🏎️' }}
            </div>
            {% if isOwner %}
                <button class="avatar-edit-btn" onclick="openAvatarPicker()" title="Changer l'avatar">
                    <i class="fa-solid fa-pen"></i>
                </button>
            {% endif %}
        </div>

        {# Nom + infos #}
        <div class="profile-identity">
            <div class="profile-name-row">
                <h1 class="profile-name" id="displayName">
                    {{ profileUser.username ?? profileUser.email|split('@')[0] }}
                </h1>
                {% if isOwner %}
                    <button class="edit-name-btn" onclick="openEditModal()" title="Modifier le pseudo">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                {% endif %}
            </div>
            <p class="profile-handle">
                <i class="fa-solid fa-at"></i> {{ profileUser.email }}
            </p>
            <div class="profile-tags">
                <span class="profile-tag tag-cyan">
                    <i class="fa-solid fa-cards-blank"></i> {{ stats.uniqueCards }} cartes uniques
                </span>
                <span class="profile-tag tag-gold">
                    <i class="fa-solid fa-coins"></i> {{ stats.credits|number_format(0, ',', ' ') }} ¢
                </span>
                {% if stats.wonAuctions > 0 %}
                    <span class="profile-tag tag-purple">
                        <i class="fa-solid fa-trophy"></i> {{ stats.wonAuctions }} enchère(s) gagnée(s)
                    </span>
                {% endif %}
            </div>
        </div>

    </div>
</section>

{# ══════════════════════════════════════════════════════════════ STATS ══ #}
<section class="profile-section">
    <div class="profile-container">

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="color:var(--accent);">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                <div class="stat-value">{{ stats.totalCards }}</div>
                <div class="stat-label">Cartes totales</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#a300ff;">
                    <i class="fa-solid fa-star"></i>
                </div>
                <div class="stat-value">{{ stats.uniqueCards }}</div>
                <div class="stat-label">Cartes uniques</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:var(--gold);">
                    <i class="fa-solid fa-box-open"></i>
                </div>
                <div class="stat-value">{{ stats.boosters }}</div>
                <div class="stat-label">Boosters ouvert</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#00ff88;">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                </div>
                <div class="stat-value">{{ stats.totalEarned|number_format(0, ',', ' ') }}</div>
                <div class="stat-label">Crédits gagnés (marché)</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:var(--accent);">
                    <i class="fa-solid fa-tag"></i>
                </div>
                <div class="stat-value">{{ stats.soldCount }}</div>
                <div class="stat-label">Ventes réalisées</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="color:#ffd700;">
                    <i class="fa-solid fa-gavel"></i>
                </div>
                <div class="stat-value">{{ stats.wonAuctions }}</div>
                <div class="stat-label">Enchères gagnées</div>
            </div>
        </div>

        {# Répartition rarités #}
        <div class="rarity-bar-wrapper">
            <h3 class="section-title">RÉPARTITION DE LA COLLECTION</h3>
            {% set total = rarityCount.common + rarityCount.rare + rarityCount.epic + rarityCount.legendary %}
            <div class="rarity-bar">
                {% if total > 0 %}
                    {% for rarity, count in rarityCount %}
                        {% if count > 0 %}
                            <div class="rarity-segment rarity-seg-{{ rarity }}"
                                 style="width: {{ (count / total * 100)|round(1) }}%"
                                 title="{{ rarity|capitalize }} : {{ count }}">
                            </div>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <div style="width:100%; background:#1a1a1a;"></div>
                {% endif %}
            </div>
            <div class="rarity-legend">
                {% for rarity, count in rarityCount %}
                    <span class="legend-item">
                        <span class="legend-dot dot-{{ rarity }}"></span>
                        {{ rarity|capitalize }} ({{ count }})
                    </span>
                {% endfor %}
            </div>
        </div>

    </div>
</section>

{# ══════════════════════════════════════════════════════════════ TABS ═══ #}
<section class="profile-section" style="padding-top: 0;">
    <div class="profile-container">

        <div class="tab-row">
            <button class="tab-btn tab-active" onclick="switchTab('collection', this)">
                <i class="fa-solid fa-car"></i> Collection
            </button>
            <button class="tab-btn" onclick="switchTab('market', this)">
                <i class="fa-solid fa-shop"></i> Marché
            </button>
            <button class="tab-btn" onclick="switchTab('auctions', this)">
                <i class="fa-solid fa-gavel"></i> Enchères
            </button>
        </div>

        {# ── Collection ─────────────────────────────────────────────────── #}
        <div id="tab-collection" class="tab-content">
            {% if userCards is empty %}
                <div class="empty-state">
                    <i class="fa-solid fa-box-open" style="font-size:3rem; color:var(--accent); opacity:0.3;"></i>
                    <p>Aucune carte pour l'instant.</p>
                </div>
            {% else %}
                {# Filtre rapide #}
                <div class="quick-filters">
                    <button class="qf-btn qf-active" onclick="filterCards('all', this)">Toutes</button>
                    <button class="qf-btn" onclick="filterCards('legendary', this)" style="color:#ffa500;">Legendary</button>
                    <button class="qf-btn" onclick="filterCards('epic', this)" style="color:#a300ff;">Epic</button>
                    <button class="qf-btn" onclick="filterCards('rare', this)" style="color:#4488ff;">Rare</button>
                    <button class="qf-btn" onclick="filterCards('common', this)">Common</button>
                    <button class="qf-btn" onclick="filterCards('mythic', this)" style="color:#ff4500;">Mythic</button>
                </div>

                <div class="cards-grid" id="cardsGrid">
                    {% for userCard in userCards %}
                        {% set card = userCard.card %}
                        <div class="mini-card rarity-{{ card.rarity|lower }}" data-rarity="{{ card.rarity|lower }}">
                            <div class="mini-card-img">
                                {% if card.imagePath %}
                                    <img src="{{ asset('images' ~ card.imagePath) }}" alt="{{ card.name }}">
                                {% else %}
                                    <div class="mini-placeholder"><i class="fa-solid fa-car"></i></div>
                                {% endif %}
                                {% if userCard.quantity > 1 %}
                                    <span class="mini-qty">x{{ userCard.quantity }}</span>
                                {% endif %}
                                <span class="mini-rarity rarity-dot-{{ card.rarity|lower }}"></span>
                            </div>
                            <div class="mini-card-info">
                                <p class="mini-name">{{ card.name }}</p>
                                <p class="mini-brand">{{ card.brand }}</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# ── Marché ─────────────────────────────────────────────────────── #}
        <div id="tab-market" class="tab-content" style="display:none;">
            {% if myListings is empty %}
                <div class="empty-state">
                    <i class="fa-solid fa-shop" style="font-size:3rem; color:var(--accent); opacity:0.3;"></i>
                    <p>Aucune activité sur le marché.</p>
                </div>
            {% else %}
                <table class="profile-table">
                    <thead>
                        <tr>
                            <th>Carte</th>
                            <th>Prix</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th>Acheteur</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for listing in myListings %}
                            <tr>
                                <td>
                                    <strong>{{ listing.card.name }}</strong>
                                    <span class="rarity-badge rarity-{{ listing.card.rarity }} badge-sm" style="margin-left:6px;">{{ listing.card.rarity|upper }}</span>
                                </td>
                                <td style="color:var(--gold);">{{ listing.price }} ¢</td>
                                <td>
                                    {% if listing.status == 'active' %}
                                        <span class="status-dot active"></span> Actif
                                    {% elseif listing.status == 'sold' %}
                                        <span class="status-dot sold"></span> Vendu
                                    {% else %}
                                        <span class="status-dot cancelled"></span> Annulé
                                    {% endif %}
                                </td>
                                <td style="color:#666; font-size:0.82rem;">{{ listing.createdAt|date('d/m/Y') }}</td>
                                <td style="color:#888; font-size:0.82rem;">
                                    {% if listing.buyer %}
                                        {{ listing.buyer.username ?? listing.buyer.email|split('@')[0] }}
                                    {% else %}—{% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

        {# ── Enchères ───────────────────────────────────────────────────── #}
        <div id="tab-auctions" class="tab-content" style="display:none;">
            {% if myAuctions is empty %}
                <div class="empty-state">
                    <i class="fa-solid fa-gavel" style="font-size:3rem; color:var(--accent); opacity:0.3;"></i>
                    <p>Aucune enchère.</p>
                </div>
            {% else %}
                <table class="profile-table">
                    <thead>
                        <tr>
                            <th>Carte</th>
                            <th>Prix départ</th>
                            <th>Prix final</th>
                            <th>Enchères</th>
                            <th>Statut</th>
                            <th>Rôle</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for auction in myAuctions %}
                            <tr>
                                <td>
                                    <strong>{{ auction.card.name }}</strong>
                                    <span class="rarity-badge rarity-{{ auction.card.rarity }} badge-sm" style="margin-left:6px;">{{ auction.card.rarity|upper }}</span>
                                </td>
                                <td style="color:#aaa;">{{ auction.startPrice }} ¢</td>
                                <td style="color:var(--gold);">{{ auction.currentPrice }} ¢</td>
                                <td style="color:var(--accent);">{{ auction.bidCount }}</td>
                                <td>
                                    {% if auction.status == 'active' and auction.endsAt > date() %}
                                        <span class="status-dot active"></span> Live
                                    {% elseif auction.status == 'ended' %}
                                        <span class="status-dot sold"></span> Terminée
                                    {% else %}
                                        <span class="status-dot cancelled"></span> Expirée
                                    {% endif %}
                                </td>
                                <td style="font-size:0.82rem;">
                                    {% if auction.seller == profileUser %}
                                        <span style="color:var(--accent);">Vendeur</span>
                                    {% else %}
                                        <span style="color:#aaa;">Enchérisseur</span>
                                    {% endif %}
                                    {% if auction.winner == profileUser %}
                                        <span style="color:#ffd700;"> 🏆</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

    </div>
</section>

{# ══════════════════════════════════════════════ MODAL EDIT PROFIL ═══ #}
{% if isOwner %}
<div id="edit-modal" class="modal-overlay" style="display:none;">
    <div class="modal-cyber">
        <h3 style="color:var(--accent); margin-bottom:20px;">
            <i class="fa-solid fa-pen-to-square"></i> Modifier le profil
        </h3>

        <div class="form-group-cyber" style="margin-bottom:16px;">
            <label>Pseudo</label>
            <input type="text" id="edit-username" class="input-cyber" style="width:100%;"
                   placeholder="Entre 3 et 30 caractères"
                   value="{{ profileUser.username ?? '' }}">
        </div>

        <div style="display:flex; gap:10px; justify-content:center; margin-top:20px;">
            <button class="btn-cyber" onclick="saveProfile()">
                <i class="fa-solid fa-check"></i> Sauvegarder
            </button>
            <button class="btn-cyber btn-outline" onclick="closeEditModal()">
                <i class="fa-solid fa-xmark"></i> Annuler
            </button>
        </div>
    </div>
</div>

{# ── Avatar picker ──────────────────────────────────────────────────── #}
<div id="avatar-modal" class="modal-overlay" style="display:none;">
    <div class="modal-cyber" style="max-width:500px;">
        <h3 style="color:var(--accent); margin-bottom:20px;">
            <i class="fa-solid fa-face-smile"></i> Choisir un avatar
        </h3>
        <div class="avatar-grid">
            {% for emoji in ['🏎️','🚗','🚀','🔥','⚡','💀','🐉','🦊','🐺','🤖','👾','🎮','🏁','🎯','🌑','🌀','⚔️','🛡️','🐍','🦅'] %}
                <button class="avatar-option" onclick="selectAvatar('{{ emoji }}')">{{ emoji }}</button>
            {% endfor %}
        </div>
        <div style="margin-top:20px; text-align:center;">
            <button class="btn-cyber btn-outline" onclick="closeAvatarModal()">
                <i class="fa-solid fa-xmark"></i> Fermer
            </button>
        </div>
    </div>
</div>
{% endif %}

{# Toast #}
<div id="toast" class="toast-cyber" style="display:none;"></div>

{# ══════════════════════════════════════════════════════════════ STYLES ═══ #}
<style>
:root {
    --gold: #ffd700;
    --accent: #00f3ff;
}

/* ── Hero ─────────────────────────────────────────────────────────────── */
.profile-hero {
    position: relative;
    background: linear-gradient(180deg, rgba(0,243,255,0.07) 0%, transparent 100%);
    border-bottom: 1px solid rgba(0,243,255,0.15);
    padding: 60px 20px 50px;
    overflow: hidden;
}
.hero-scan-lines {
    position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,243,255,0.015) 3px, rgba(0,243,255,0.015) 4px);
}
.profile-hero-inner {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; gap: 40px; flex-wrap: wrap;
}

/* Avatar */
.avatar-wrapper {
    position: relative; flex-shrink: 0;
    width: 110px; height: 110px;
}
.avatar-ring {
    position: absolute; inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    animation: spinRing 8s linear infinite;
    background: conic-gradient(var(--accent), transparent, var(--accent));
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 3px), white calc(100% - 3px));
}
@keyframes spinRing { to { transform: rotate(360deg); } }
.avatar-display {
    width: 110px; height: 110px; border-radius: 50%;
    background: rgba(0,243,255,0.08);
    border: 2px solid rgba(0,243,255,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    cursor: default;
}
.avatar-edit-btn {
    position: absolute; bottom: 2px; right: 2px;
    background: var(--accent); color: #000;
    border: none; border-radius: 50%;
    width: 26px; height: 26px;
    font-size: 0.7rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s;
}
.avatar-edit-btn:hover { transform: scale(1.15); }

/* Identity */
.profile-identity { flex: 1; min-width: 200px; }
.profile-name-row { display: flex; align-items: center; gap: 12px; margin-bottom: 6px; }
.profile-name {
    font-size: 2rem; color: white; margin: 0;
    font-family: 'Rajdhani', monospace; letter-spacing: 2px;
    text-transform: uppercase;
}
.edit-name-btn {
    background: transparent; border: 1px solid rgba(0,243,255,0.3);
    color: var(--accent); border-radius: 6px;
    padding: 4px 8px; font-size: 0.75rem; cursor: pointer;
    transition: all 0.2s;
}
.edit-name-btn:hover { background: rgba(0,243,255,0.1); }
.profile-handle { color: #666; font-size: 0.85rem; margin: 0 0 12px; }
.profile-tags { display: flex; gap: 10px; flex-wrap: wrap; }
.profile-tag {
    font-size: 0.78rem; padding: 3px 10px; border-radius: 20px;
    letter-spacing: 0.5px;
}
.tag-cyan   { background: rgba(0,243,255,0.1); color: var(--accent); border: 1px solid rgba(0,243,255,0.3); }
.tag-gold   { background: rgba(255,215,0,0.1); color: var(--gold); border: 1px solid rgba(255,215,0,0.3); }
.tag-purple { background: rgba(163,0,255,0.1); color: #a300ff; border: 1px solid rgba(163,0,255,0.3); }

/* ── Stats grid ───────────────────────────────────────────────────────── */
.profile-section { padding: 40px 20px; }
.profile-container { max-width: 1200px; margin: 0 auto; }
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px; margin-bottom: 40px;
}
.stat-card {
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; padding: 20px; text-align: center;
    transition: border-color 0.2s;
}
.stat-card:hover { border-color: rgba(0,243,255,0.3); }
.stat-icon { font-size: 1.5rem; margin-bottom: 10px; }
.stat-value { font-size: 1.6rem; font-weight: bold; color: white; font-family: 'Rajdhani', monospace; }
.stat-label { font-size: 0.72rem; color: #666; letter-spacing: 1px; text-transform: uppercase; margin-top: 4px; }

/* ── Rarity bar ───────────────────────────────────────────────────────── */
.rarity-bar-wrapper { margin-bottom: 40px; }
.section-title {
    color: var(--accent); font-size: 0.8rem; letter-spacing: 3px;
    margin-bottom: 16px; opacity: 0.8;
}
.rarity-bar {
    height: 10px; border-radius: 5px; overflow: hidden;
    display: flex; background: #1a1a1a;
}
.rarity-segment { height: 100%; transition: width 0.5s ease; }
.rarity-seg-legendary { background: #ffa500; }
.rarity-seg-epic      { background: #a300ff; }
.rarity-seg-rare      { background: #4488ff; }
.rarity-seg-common    { background: #444; }
.rarity-legend { display: flex; gap: 20px; margin-top: 10px; flex-wrap: wrap; }
.legend-item { font-size: 0.78rem; color: #888; display: flex; align-items: center; gap: 6px; }
.legend-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
.dot-legendary { background: #ffa500; }
.dot-epic      { background: #a300ff; }
.dot-rare      { background: #4488ff; }
.dot-common    { background: #444; }

/* ── Tabs ─────────────────────────────────────────────────────────────── */
.tab-row {
    display: flex; gap: 0; margin-bottom: 24px;
    border-bottom: 2px solid rgba(0,243,255,0.2);
}
.tab-btn {
    background: transparent; border: none;
    border-bottom: 3px solid transparent;
    color: #666; padding: 10px 22px;
    font-family: 'Rajdhani', monospace;
    font-size: 0.85rem; letter-spacing: 1px;
    cursor: pointer; transition: all 0.2s;
    margin-bottom: -2px;
}
.tab-btn:hover { color: var(--accent); }
.tab-btn.tab-active { color: var(--accent); border-bottom-color: var(--accent); }

/* ── Cards grid ───────────────────────────────────────────────────────── */
.quick-filters { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
.qf-btn {
    background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1);
    color: #888; padding: 5px 14px; border-radius: 20px;
    font-size: 0.78rem; cursor: pointer; transition: all 0.15s;
}
.qf-btn:hover, .qf-btn.qf-active { border-color: var(--accent); color: var(--accent); background: rgba(0,243,255,0.08); }
.cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
}
.mini-card {
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px; overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: default;
}
.mini-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,243,255,0.15); }
.mini-card.rarity-legendary { border-color: rgba(255,165,0,0.4); }
.mini-card.rarity-epic      { border-color: rgba(163,0,255,0.4); }
.mini-card.rarity-rare      { border-color: rgba(0,100,255,0.4); }
.mini-card-img {
    position: relative; height: 80px;
    background: rgba(0,0,0,0.5);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
}
.mini-card-img img { width: 100%; height: 100%; object-fit: cover; }
.mini-placeholder { font-size: 1.8rem; color: #333; }
.mini-qty {
    position: absolute; bottom: 4px; right: 4px;
    background: rgba(0,0,0,0.85); color: var(--accent);
    font-size: 0.65rem; padding: 1px 5px; border-radius: 3px;
    border: 1px solid var(--accent);
}
.mini-rarity {
    position: absolute; top: 4px; left: 4px;
    width: 6px; height: 6px; border-radius: 50%;
}
.rarity-dot-legendary { background: #ffa500; box-shadow: 0 0 6px #ffa500; }
.rarity-dot-epic      { background: #a300ff; box-shadow: 0 0 6px #a300ff; }
.rarity-dot-rare      { background: #4488ff; box-shadow: 0 0 6px #4488ff; }
.rarity-dot-common    { background: #555; }
.mini-card-info { padding: 6px 8px; }
.mini-name  { color: white; font-size: 0.72rem; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mini-brand { color: #666; font-size: 0.65rem; margin: 2px 0 0; }

/* ── Table ────────────────────────────────────────────────────────────── */
.profile-table { width: 100%; border-collapse: collapse; }
.profile-table th {
    color: var(--accent); font-size: 0.78rem; letter-spacing: 1px;
    text-align: left; padding: 10px 12px;
    border-bottom: 1px solid rgba(0,243,255,0.2);
}
.profile-table td { padding: 12px; border-bottom: 1px solid rgba(255,255,255,0.04); color: #ccc; font-size: 0.88rem; }
.status-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 5px; }
.status-dot.active    { background: #00ff88; box-shadow: 0 0 6px #00ff88; }
.status-dot.sold      { background: var(--gold); }
.status-dot.cancelled { background: #555; }

/* ── Badges ───────────────────────────────────────────────────────────── */
.rarity-badge {
    font-size: 0.65rem; padding: 2px 7px; border-radius: 4px; font-weight: bold; letter-spacing: 1px;
}
.rarity-badge.rarity-legendary { background: rgba(255,165,0,0.2); color: #ffa500; border: 1px solid #ffa500; }
.rarity-badge.rarity-epic      { background: rgba(163,0,255,0.2); color: #a300ff; border: 1px solid #a300ff; }
.rarity-badge.rarity-rare      { background: rgba(0,100,255,0.2); color: #4488ff; border: 1px solid #4488ff; }
.rarity-badge.rarity-common    { background: rgba(255,255,255,0.05); color: #888; border: 1px solid #444; }
.badge-sm { font-size: 0.62rem; padding: 1px 5px; }

/* ── Modal ────────────────────────────────────────────────────────────── */
.modal-overlay {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(0,0,0,0.85);
    display: flex; align-items: center; justify-content: center;
}
.modal-cyber {
    background: #0d0d0d; border: 2px solid var(--accent);
    border-radius: 12px; padding: 40px;
    max-width: 440px; width: 90%; text-align: center;
}
.input-cyber {
    background: rgba(0,0,0,0.6); border: 1px solid rgba(0,243,255,0.3);
    border-radius: 6px; color: white; padding: 8px 12px;
    font-size: 0.9rem; outline: none; transition: border-color 0.2s;
}
.input-cyber:focus { border-color: var(--accent); }
.form-group-cyber label { display: block; color: #aaa; font-size: 0.78rem; letter-spacing: 1px; margin-bottom: 6px; text-align: left; }
.btn-outline { background: transparent !important; border: 1px solid var(--accent) !important; color: var(--accent) !important; }

/* Avatar picker */
.avatar-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;
}
.avatar-option {
    background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; font-size: 1.6rem; padding: 10px;
    cursor: pointer; transition: all 0.15s;
}
.avatar-option:hover { border-color: var(--accent); background: rgba(0,243,255,0.1); transform: scale(1.1); }
.avatar-option.selected { border-color: var(--accent); background: rgba(0,243,255,0.15); }

/* Toast */
.toast-cyber {
    position: fixed; bottom: 30px; right: 30px; z-index: 2000;
    background: #0a0a0a; border: 1px solid var(--accent);
    border-radius: 8px; padding: 14px 22px; color: white;
    font-size: 0.9rem; min-width: 250px;
    box-shadow: 0 4px 20px rgba(0,243,255,0.3);
    animation: slideIn 0.3s ease;
}
@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

/* Empty state */
.empty-state { text-align: center; padding: 50px 20px; color: #555; }
.empty-state p { margin-top: 12px; font-size: 0.95rem; }

.mini-card.rarity-mythic    { border-color: rgba(255,69,0,0.6); }
.rarity-dot-mythic          { background: #ff4500; box-shadow: 0 0 6px #ff4500; }
.rarity-badge.rarity-mythic { background: rgba(255,69,0,0.2); color: #ff4500; border: 1px solid #ff4500; }
</style>

{# ══════════════════════════════════════════════════════════════ JS ═════ #}
<script>
// ── Tabs ──────────────────────────────────────────────────────────────────
function switchTab(tab, btn) {
    document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('tab-active'));
    document.getElementById('tab-' + tab).style.display = 'block';
    btn.classList.add('tab-active');
}

// ── Filter cards ──────────────────────────────────────────────────────────
function filterCards(rarity, btn) {
    document.querySelectorAll('.qf-btn').forEach(b => b.classList.remove('qf-active'));
    btn.classList.add('qf-active');
    document.querySelectorAll('.mini-card').forEach(card => {
        const cardRarity = (card.dataset.rarity ?? '').toLowerCase().trim();
        card.style.display = (rarity === 'all' || cardRarity === rarity) ? '' : 'none';
    });
}

// ── Toast ─────────────────────────────────────────────────────────────────
function showToast(msg, isError = false) {
    const t = document.getElementById('toast');
    t.innerHTML = (isError ? '❌ ' : '✅ ') + msg;
    t.style.borderColor = isError ? '#ff4444' : 'var(--accent)';
    t.style.display = 'block';
    setTimeout(() => t.style.display = 'none', 4000);
}

// ── Edit modal ────────────────────────────────────────────────────────────
function openEditModal()  { document.getElementById('edit-modal').style.display = 'flex'; }
function closeEditModal() { document.getElementById('edit-modal').style.display = 'none'; }

async function saveProfile() {
    const username = document.getElementById('edit-username').value.trim();
    const body = new URLSearchParams({ username });

    try {
        const res  = await fetch('/profile/update', { method: 'POST', body });
        const data = await res.json();
        if (data.success) {
            document.getElementById('displayName').textContent = data.username;
            closeEditModal();
            showToast(data.message);
        } else {
            showToast(data.message, true);
        }
    } catch {
        showToast('Erreur réseau', true);
    }
}

// ── Avatar picker ─────────────────────────────────────────────────────────
let pendingAvatar = null;

function openAvatarPicker()  { document.getElementById('avatar-modal').style.display = 'flex'; }
function closeAvatarModal()  { document.getElementById('avatar-modal').style.display = 'none'; }

async function selectAvatar(emoji) {
    document.querySelectorAll('.avatar-option').forEach(b => b.classList.remove('selected'));
    event.target.classList.add('selected');

    const body = new URLSearchParams({ avatar: emoji });
    try {
        const res  = await fetch('/profile/update', { method: 'POST', body });
        const data = await res.json();
        if (data.success) {
            document.getElementById('avatarDisplay').textContent = emoji;
            closeAvatarModal();
            showToast('Avatar mis à jour !');
        } else {
            showToast(data.message, true);
        }
    } catch {
        showToast('Erreur réseau', true);
    }
}
</script>

{% endblock %}
