{% extends 'base.html.twig' %}

{% block title %}Panel Admin - Redline Rivals{% endblock %}

{% block body %}

<section class="hero" style="height: 35vh;">
    <h1 class="glitch-title">PANEL ADMIN</h1>
    <p style="letter-spacing: 3px; color: #ccc; font-size: 1rem;">SYSTÈME DE CONTRÔLE</p>
</section>

<section class="section-bg-scan">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

        {# Stats #}
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 50px;">
            <div style="background: rgba(255,0,60,0.07); border: 1px solid var(--primary); padding: 30px; border-radius: 12px; text-align: center;">
                <p style="font-size: 3rem; font-weight: bold; color: var(--primary); margin: 0; font-family: monospace;">{{ totalUsers }}</p>
                <p style="color: #aaa; text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; margin: 10px 0 0;">Utilisateurs</p>
            </div>
            <div style="background: rgba(0,255,200,0.05); border: 1px solid var(--accent); padding: 30px; border-radius: 12px; text-align: center;">
                <p style="font-size: 3rem; font-weight: bold; color: var(--accent); margin: 0; font-family: monospace;">{{ totalAdmins }}</p>
                <p style="color: #aaa; text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; margin: 10px 0 0;">Administrateurs</p>
            </div>
        </div>

        {# Navigation admin #}
        <h2 style="color: var(--accent); text-transform: uppercase; letter-spacing: 3px; margin-bottom: 25px; font-size: 0.9rem;">
            <i class="fa-solid fa-sliders"></i> MODULES
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">

            <a href="{{ path('app_admin_users') }}" style="text-decoration:none;">
                <div style="background: rgba(0,0,0,0.5); border: 1px solid #333; padding: 30px; border-radius: 12px; transition: all 0.2s; cursor: pointer;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='#333'">
                    <i class="fa-solid fa-users" style="font-size: 2rem; color: var(--accent); margin-bottom: 15px; display: block;"></i>
                    <h3 style="color: white; text-transform: uppercase; letter-spacing: 2px; margin: 0 0 8px; font-size: 1rem;">Utilisateurs</h3>
                    <p style="color: #555; font-size: 0.85rem; margin: 0;">Gérer les rôles et les crédits</p>
                </div>
            </a>

            <a href="{{ path('app_game_shop') }}" style="text-decoration:none;">
                <div style="background: rgba(0,0,0,0.5); border: 1px solid #333; padding: 30px; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='#333'">
                    <i class="fa-solid fa-store" style="font-size: 2rem; color: var(--primary); margin-bottom: 15px; display: block;"></i>
                    <h3 style="color: white; text-transform: uppercase; letter-spacing: 2px; margin: 0 0 8px; font-size: 1rem;">Shop</h3>
                    <p style="color: #555; font-size: 0.85rem; margin: 0;">Voir la boutique</p>
                </div>
            </a>

            <a href="{{ path('app_game_market') }}" style="text-decoration:none;">
                <div style="background: rgba(0,0,0,0.5); border: 1px solid #333; padding: 30px; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--gold)'" onmouseout="this.style.borderColor='#333'">
                    <i class="fa-solid fa-chart-line" style="font-size: 2rem; color: var(--gold); margin-bottom: 15px; display: block;"></i>
                    <h3 style="color: white; text-transform: uppercase; letter-spacing: 2px; margin: 0 0 8px; font-size: 1rem;">Marché</h3>
                    <p style="color: #555; font-size: 0.85rem; margin: 0;">Surveiller les transactions</p>
                </div>
            </a>

        </div>

    </div>
</section>

{% endblock %}
