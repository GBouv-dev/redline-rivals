{% extends 'base.html.twig' %}

{% block title %}New Card{% endblock %}

{% block page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/tables.css') }}">
    <link rel="stylesheet" href="{{ asset('css/card-edit.css') }}">
{% endblock %}

{% block body %}
    <div class="card-edit-container">
        <h1>Create New Card</h1>

        <div class="card-edit-form">
            {{ form_start(form) }}
                {# Nom de la carte #}
                <div class="form-group">
                    {{ form_label(form.name, 'Card Name', {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.name, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'e.g., Toyota Supra MK4'
                        }
                    }) }}
                    {{ form_errors(form.name, {'attr': {'class': 'form-error'}}) }}
                    <span class="form-help">Enter the vehicle name</span>
                </div>

                {# Marque #}
                <div class="form-group">
                    {{ form_label(form.brand, 'Brand', {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.brand, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'Toyota, Nissan, Porsche...'
                        }
                    }) }}
                    {{ form_errors(form.brand, {'attr': {'class': 'form-error'}}) }}
                    <span class="form-help">Vehicle manufacturer</span>
                </div>

                {# Puissance #}
                <div class="form-group">
                    {{ form_label(form.horsepower, 'Horsepower', {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.horsepower, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': '350'
                        }
                    }) }}
                    {{ form_errors(form.horsepower, {'attr': {'class': 'form-error'}}) }}
                    <span class="form-help">Engine power in HP</span>
                </div>

                {# Rareté #}
                <div class="form-group">
                    {{ form_label(form.rarity, 'Rarity', {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.rarity, {
                        'attr': {
                            'class': 'form-control'
                        }
                    }) }}
                    {{ form_errors(form.rarity, {'attr': {'class': 'form-error'}}) }}
                    
                    <div class="rarity-help">
                        <div class="rarity-examples">
                            <span class="rarity-example common">Common</span>
                            <span class="rarity-example rare">Rare</span>
                            <span class="rarity-example epic">Epic</span>
                            <span class="rarity-example legendary">Legendary</span>
                            <span class="rarity-example mythic">Mythic</span>
                        </div>
                        <span class="form-help">Card rarity level</span>
                    </div>
                </div>

                {# Chemin de l'image #}
                <div class="form-group">
                    {{ form_label(form.imagePath, 'Image Path') }}
                    {{ form_widget(form.imagePath, {
                        'attr': {
                            'class': 'form-control',
                            'placeholder': 'car-image.jpg'
                        }
                    }) }}
                    {{ form_errors(form.imagePath, {'attr': {'class': 'form-error'}}) }}
                    
                    <div class="image-info">
                        <i class="fas fa-info-circle"></i>
                        <span>Place your image in <code>public/images/</code> folder</span>
                    </div>
                </div>

                {# Afficher les autres champs s'il y en a #}
                {{ form_rest(form) }}

                {# Boutons d'action #}
                <div class="form-actions">
                    <button type="submit" class="form-btn btn-create">
                        <i class="fas fa-plus"></i> Create Card
                    </button>
                    
                    <a href="{{ path('app_card_index') }}" class="form-btn btn-back">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
