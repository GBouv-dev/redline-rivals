{% extends 'base.html.twig' %}

{% block title %}{{ card.name }} - Redline Rivals{% endblock %}

{% block page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/cardDetail.css') }}">
{% endblock %}

{% block body %}

{% set rarityColors = {
    'legendary': '#ffd700',
    'mythic':    '#ff0077',
    'epic':      '#c353ff',
    'rare':      '#00f3ff',
    'uncommon':  '#4CAF50',
    'common':    '#9e9e9e'
} %}
{% set rc = rarityColors[card.rarity|lower] ?? '#9e9e9e' %}

<div class="card-show-wrap">

    {# ── Colonne gauche : carte TCG ── #}
    <div class="cs-left">
        <div class="cs-card" style="--rc: {{ rc }};">
            <div class="cs-img-wrap">
                {% if card.imagePath %}
                    <img src="{{ asset('images/' ~ card.imagePath) }}" alt="{{ card.name }}">
                {% else %}
                    <div class="cs-img-placeholder"><i class="fa-solid fa-car-side"></i></div>
                {% endif %}
                <div class="cs-img-overlay"></div>
                <div class="cs-scanline"></div>
                <span class="cs-rarity-badge">{{ card.rarity }}</span>
                <span class="cs-id-badge">#{{ card.id }}</span>
                {% if card.rarity|lower in ['legendary', 'mythic', 'epic'] %}
                    <div class="cs-shine"></div>
                {% endif %}
            </div>
            <div class="cs-card-footer">
                <p class="cs-card-name">{{ card.name }}</p>
                <p class="cs-card-brand">{{ card.brand }}</p>
            </div>
        </div>

        <a href="{{ path('app_card_index') }}" class="btn-cyber" style="display:block; text-align:center; margin-top:20px; font-size:.85rem;">
            <i class="fa-solid fa-arrow-left"></i> RETOUR AU GARAGE
        </a>
    </div>

    {# ── Colonne droite ── #}
    <div class="cs-right">

        {# Header #}
        <div>
            <p style="font-family:var(--font-head); font-size:.75rem; letter-spacing:3px; text-transform:uppercase; color:{{ rc }}; display:flex; align-items:center; gap:8px; margin:0 0 12px;">
                <span style="width:8px; height:8px; border-radius:50%; background:{{ rc }}; flex-shrink:0; display:inline-block;"></span>
                {{ card.rarity|upper }}
            </p>
            <h1 style="font-family:var(--font-head); font-size:2.5rem; font-weight:900; color:white; text-transform:uppercase; letter-spacing:2px; margin:0 0 8px; line-height:1;">{{ card.name }}</h1>
            <p style="font-size:.85rem; color:#444; text-transform:uppercase; letter-spacing:3px; margin:0;">{{ card.brand }}</p>
        </div>

        {# Stats de combat #}
        <div>
            <p class="cs-section-label">STATS DE COMBAT</p>
            <div class="cs-combat-grid">
                <div class="cs-combat-stat" style="--rc: {{ rc }};">
                    <i class="fa-solid fa-gauge-high"></i>
                    <span class="cs-cv">{{ card.horsepower ?? '—' }}</span>
                    <span class="cs-cu">CH</span>
                    <span class="cs-cl">PUISSANCE</span>
                </div>
                <div class="cs-combat-stat" style="--rc: {{ rc }};">
                    <i class="fa-solid fa-road"></i>
                    <span class="cs-cv">{{ card.speed ?? '—' }}</span>
                    <span class="cs-cu">km/h</span>
                    <span class="cs-cl">VITESSE MAX</span>
                </div>
                <div class="cs-combat-stat" style="--rc: {{ rc }};">
                    <i class="fa-solid fa-bolt"></i>
                    <span class="cs-cv">{{ card.acceleration ?? '—' }}</span>
                    <span class="cs-cu">sec</span>
                    <span class="cs-cl">0-100 KM/H</span>
                </div>
                <div class="cs-combat-stat" style="--rc: {{ rc }};">
                    <i class="fa-solid fa-circle-notch"></i>
                    <span class="cs-cv">{{ card.handling ?? '—' }}</span>
                    <span class="cs-cu">/ 100</span>
                    <span class="cs-cl">MANIABILITÉ</span>
                </div>
            </div>
        </div>

        {# Barre de puissance #}
        <div>
            <p class="cs-section-label">INDICE DE PUISSANCE</p>
            <div style="position:relative; height:8px; background:rgba(255,255,255,.05); border-radius:4px; overflow:hidden;">
                {% set pct = min(card.horsepower / 1500 * 100, 100) %}
                <div style="height:100%; width:{{ pct }}%; background:linear-gradient(90deg, {{ rc }}, white); border-radius:4px; box-shadow:0 0 10px {{ rc }}; animation:barGrow .8s .3s both ease-out;"></div>
            </div>
            <span style="font-size:.7rem; color:#333; letter-spacing:1px; margin-top:8px; display:block; text-align:right; font-family:monospace;">{{ card.horsepower ?? 0 }} / 1500 CH</span>
        </div>

        {# Données techniques #}
        <div>
            <p class="cs-section-label">DONNÉES TECHNIQUES</p>
            <div class="cs-details-list">
                <div class="cs-detail-row">
                    <span class="cs-detail-key">ID SYSTÈME</span>
                    <span class="cs-detail-val" style="color:{{ rc }}; font-family:monospace;">#{{ card.id }}</span>
                </div>
                <div class="cs-detail-row">
                    <span class="cs-detail-key">MODÈLE</span>
                    <span class="cs-detail-val">{{ card.name }}</span>
                </div>
                <div class="cs-detail-row">
                    <span class="cs-detail-key">CONSTRUCTEUR</span>
                    <span class="cs-detail-val">{{ card.brand }}</span>
                </div>
                <div class="cs-detail-row">
                    <span class="cs-detail-key">POIDS</span>
                    <span class="cs-detail-val">{{ card.weight ? card.weight ~ ' kg' : '—' }}</span>
                </div>
                <div class="cs-detail-row">
                    <span class="cs-detail-key">RARETÉ</span>
                    <span class="cs-detail-val" style="color:{{ rc }};">{{ card.rarity|upper }}</span>
                </div>
            </div>
        </div>

        {# Admin #}
        {% if is_granted('ROLE_ADMIN') %}
        <div>
            <p class="cs-section-label">ADMINISTRATION</p>
            <div style="display:flex; gap:10px;">
                <a href="{{ path('app_card_edit', {id: card.id}) }}" class="btn-cyber" style="flex:1; text-align:center; font-size:.85rem;">
                    <i class="fa-solid fa-wrench"></i> MODIFIER
                </a>
                {{ include('card/_delete_form.html.twig', {'btn_class': 'cs-delete-btn'}) }}
            </div>
        </div>
        {% endif %}

    </div>
</div>

{% endblock %}
