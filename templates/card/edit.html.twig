{% extends 'base.html.twig' %}

{% block title %}Edit Card{% endblock %}

{% block page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/tables.css') }}">
    <link rel="stylesheet" href="{{ asset('css/cardEdit.css') }}">
{% endblock %}

{% block body %}
    <div class="card-edit-container">
        <h1>Edit Card</h1>

        <div class="card-edit-form">
            {# Formulaire d'édition #}
            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.name, null, {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Enter card name...'}}) }}
                    {{ form_errors(form.name, {'attr': {'class': 'form-error'}}) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.brand, null, {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.brand, {'attr': {'class': 'form-control', 'placeholder': 'Enter brand name...'}}) }}
                    {{ form_errors(form.brand, {'attr': {'class': 'form-error'}}) }}
                </div>

                <div class="form-group">
                    {{ form_label(form.horsepower, null, {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.horsepower, {'attr': {'class': 'form-control', 'placeholder': 'Enter horsepower...'}}) }}
                    {{ form_errors(form.horsepower, {'attr': {'class': 'form-error'}}) }}
                    <span class="form-help">Enter the power in HP (e.g., 350)</span>
                </div>

                <div class="form-group">
                    {{ form_label(form.rarity, null, {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(form.rarity, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.rarity, {'attr': {'class': 'form-error'}}) }}
                    <span class="form-help">Select the card rarity level</span>
                </div>

                <div class="form-group">
                    {{ form_label(form.imagePath) }}
                    
                    {# Preview de l'image actuelle si elle existe #}
                    {% if form.vars.data.imagePath %}
                        <div class="image-preview">
                            <span class="image-preview-label">// Current Image</span>
                            <img src="{{ asset('images/' ~ form.vars.data.imagePath) }}" alt="Current card image">
                        </div>
                    {% endif %}
                    
                    {{ form_widget(form.imagePath, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.imagePath, {'attr': {'class': 'form-error'}}) }}
                    <span class="form-help">Upload a new image to replace the current one</span>
                </div>

                {# Afficher les autres champs s'il y en a #}
                {{ form_rest(form) }}

                {# Boutons d'action #}
                <div class="form-actions">
                    <button type="submit" class="form-btn btn-update">
                        <i class="fas fa-save"></i> Update
                    </button>
                    
                    <a href="{{ path('app_card_index') }}" class="form-btn btn-back-list">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            {{ form_end(form) }}

            {# Zone de danger pour la suppression #}
            <div class="danger-zone">
                <div class="danger-zone-content">
                    <div class="danger-zone-text">
                        <h3>Delete this card</h3>
                        <p>This action is permanent and cannot be undone.</p>
                    </div>
                    {{ include('card/_delete_form.html.twig', {
                        'btn_class': 'form-btn btn-delete-form'
                    }) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
