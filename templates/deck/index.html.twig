{% extends 'base.html.twig' %}

{% block title %}Deck Index // Redline{% endblock %}

{% block page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/tables.css') }}">
{% endblock %}

{% block body %}
    {# Conteneur principal avec le fond grille #}
    <div class="section-bg-grid" style="min-height: 100vh;">
        
        <div class="container" style="max-width: 1200px; margin: 0 auto; padding-top: 40px;">

            {# Fil d'ariane style terminal #}
            <div style="color: var(--accent); font-family: monospace; letter-spacing: 2px; margin-bottom: 10px; font-size: 0.9rem;">
                SYSTEM // DATA_ACCESS // DECKS
            </div>

            {# Titre principal #}
            <h1 class="glitch-title" style="text-align: left; margin-bottom: 30px; font-style: italic;">
                DECK INDEX
            </h1>

            {# Bouton de création (Style + NEW ASSET) #}
            <div style="margin-bottom: 30px;">
                <a href="{{ path('app_deck_new') }}" class="btn-cyber btn-primary">
                    <i class="fas fa-plus"></i> NEW ASSET
                </a>
            </div>

            {# Le Tableau Cyberpunk #}
            <div class="cyber-table-container">
                <table class="cyber-table">
                    <thead>
                        <tr>
                            <th>ID_KEY</th>
                            <th>DECK_NAME</th>
                            <th>CAPACITY (MAX)</th>
                            <th>OPERATIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for deck in decks %}
                        <tr class="fade-in-row">
                            {# ID avec couleur accentuée #}
                            <td class="text-accent" style="font-family: monospace; font-size: 1.1rem;">
                                #{{ deck.id }}
                            </td>
                            
                            {# Nom en blanc/gras #}
                            <td style="font-weight: bold; color: white; letter-spacing: 1px;">
                                {{ deck.name }}
                            </td>
                            
                            {# MaxCards avec unité #}
                            <td style="color: #ccc;">
                                {{ deck.maxCards }} <span style="font-size: 0.8rem; opacity: 0.7;">UNITS</span>
                            </td>

                            {# Actions avec icônes #}
                            <td>
                                {# Bouton SHOW (Oeil) #}
                                <a href="{{ path('app_deck_show', {'id': deck.id}) }}" class="btn-icon" title="Inspecter">
                                    <i class="fas fa-eye"></i>
                                </a>
                                
                                {# Bouton EDIT (Clé à molette) - Style 'alert' pour le rouge #}
                                <a href="{{ path('app_deck_edit', {'id': deck.id}) }}" class="btn-icon alert" title="Configurer">
                                    <i class="fas fa-wrench"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" style="padding: 40px; text-align: center; color: #666; font-family: monospace;">
                                // ERROR 404: NO DATA FOUND IN SECTOR //
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Footer décoratif style terminal #}
            <div style="margin-top: 15px; font-family: monospace; color: #444; font-size: 0.8rem;">
                END OF STREAM // 0010110
            </div>

        </div>
    </div>
{% endblock %}