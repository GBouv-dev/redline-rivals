{% extends 'base.html.twig' %}

{% block title %}Combat #{{ battle.id }} - Redline Rivals{% endblock %}

{% block body %}

<div id="battleApp" style="min-height: 100vh; padding: 20px; max-width: 1200px; margin: 0 auto;">

    {# ── Header score ── #}
    <div
        style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; background:rgba(0,0,0,0.6); border:1px solid #222; padding:20px 30px; border-radius:12px;">
        <div style="text-align:center; flex:1;">
            <p style="color:#aaa; font-size:.8rem; text-transform:uppercase; letter-spacing:2px; margin:0 0 5px;">Vous
            </p>
            <p id="scoreMe"
                style="font-size:3rem; font-weight:bold; color:var(--accent); margin:0; font-family:monospace;">0</p>
        </div>
        <div style="text-align:center; padding:0 30px;">
            <p style="color:var(--primary); font-size:1.2rem; font-weight:bold; letter-spacing:4px; margin:0;">VS</p>
            <p id="roundCount" style="color:#555; font-size:.75rem; margin:4px 0 0;">Round 0</p>
        </div>
        <div style="text-align:center; flex:1;">
            <p style="color:#aaa; font-size:.8rem; text-transform:uppercase; letter-spacing:2px; margin:0 0 5px;">
                Adversaire</p>
            <p id="scoreOpp"
                style="font-size:3rem; font-weight:bold; color:var(--primary); margin:0; font-family:monospace;">0</p>
        </div>
    </div>

    {# ── Critère du round ── #}
    <div id="criterionBanner" style="display:none; text-align:center; margin-bottom:20px;">
        <div
            style="display:inline-flex; align-items:center; gap:12px; padding:10px 28px; background:rgba(0,0,0,0.5); border:1px solid #222; border-radius:30px;">
            <span style="color:#444; font-size:.7rem; text-transform:uppercase; letter-spacing:2px;">Critère du
                round</span>
            <span id="criterionLabel"
                style="font-family:var(--font-head); font-size:1rem; font-weight:bold; letter-spacing:2px; color:var(--accent);"></span>
        </div>
    </div>

    {# ── Statut ── #}
    <div
        style="text-align:center; margin-bottom:25px; padding:14px; border-radius:8px; background:rgba(255,255,255,.03); border:1px solid #222;">
        <p id="statusText" style="color:#aaa; margin:0; font-size:1rem; letter-spacing:2px; text-transform:uppercase;">
            <i class="fa-solid fa-satellite-dish fa-spin"></i> Connexion...
        </p>
    </div>

    {# ── Main ── #}
    <div id="handSection" style="display:none; margin-bottom:40px;">
        <h3
            style="color:var(--accent); text-transform:uppercase; letter-spacing:2px; margin-bottom:20px; font-size:.9rem;">
            <i class="fa-solid fa-hand"></i> VOTRE MAIN
        </h3>
        <div id="hand" style="display:flex; gap:15px; flex-wrap:wrap; justify-content:center;"></div>
    </div>

    {# ── Attente ── #}
    <div id="waitingSection" style="display:none; text-align:center; padding:40px;">
        <i class="fa-solid fa-hourglass-half fa-spin"
            style="font-size:2.5rem; color:var(--primary); margin-bottom:15px; display:block;"></i>
        <p style="color:#aaa; font-size:1rem; text-transform:uppercase; letter-spacing:2px;">En attente d'un
            adversaire...</p>
    </div>

    {# ── Historique ── #}
    <div style="margin-top:30px;">
        <h3 style="color:#2a2a2a; text-transform:uppercase; letter-spacing:2px; margin-bottom:15px; font-size:.85rem;">
            <i class="fa-solid fa-history"></i> HISTORIQUE
        </h3>
        <div id="roundsList" style="display:flex; flex-direction:column; gap:8px;"></div>
    </div>

    {# ── Game over overlay ── #}
    <div id="gameOverOverlay"
        style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.92); z-index:9999; align-items:center; justify-content:center;">
        <div
            style="text-align:center; padding:60px 40px; background:#0d0d0d; border:2px solid var(--primary); border-radius:20px; max-width:500px;">
            <div id="gameOverIcon" style="font-size:5rem; margin-bottom:20px;"></div>
            <h2 id="gameOverTitle"
                style="font-size:2.5rem; text-transform:uppercase; letter-spacing:4px; margin-bottom:10px;"></h2>
            <p id="gameOverSub" style="color:#aaa; margin-bottom:40px;"></p>
            <a href="{{ path('app_game_arena') }}" class="btn-cyber">
                <i class="fa-solid fa-redo"></i> REVANCHE
            </a>
        </div>
    </div>
</div>

<style>
    .card-battle {
        width: 155px;
        background: #07070e;
        border: 2px solid #222;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
        overflow: hidden;
    }

    .card-battle:hover:not(.played) {
        border-color: var(--accent);
        transform: translateY(-10px);
        box-shadow: 0 12px 30px rgba(0, 243, 255, 0.2);
    }

    .card-battle.played {
        opacity: .35;
        cursor: not-allowed;
        filter: grayscale(1);
    }

    .card-battle img {
        width: 100%;
        height: 100px;
        object-fit: cover;
        display: block;
    }

    .card-battle .cb-placeholder {
        width: 100%;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: #1a1a1a;
    }

    .card-battle .cb-info {
        padding: 8px 9px 10px;
    }

    .card-battle .cb-name {
        font-size: .7rem;
        font-weight: bold;
        color: white;
        text-transform: uppercase;
        letter-spacing: .5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 7px;
    }

    .card-battle .cb-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3px;
    }

    .cb-stat {
        background: rgba(255, 255, 255, .03);
        border: 1px solid rgba(255, 255, 255, .05);
        border-radius: 4px;
        padding: 3px 2px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1px;
        transition: border-color .2s;
    }

    .cb-stat.active {
        border-color: var(--accent);
    }

    .cb-stat-lbl {
        font-size: .48rem;
        color: #2a2a3a;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .cb-stat-val {
        font-family: var(--font-head);
        font-size: .72rem;
        font-weight: bold;
        color: var(--accent);
    }

    .cb-stat.active .cb-stat-val {
        color: white;
    }

    .rarity-legendary {
        border-color: var(--gold) !important;
    }

    .rarity-mythic {
        border-color: #ff0077 !important;
    }

    .rarity-epic {
        border-color: #c353ff !important;
    }

    .rarity-rare {
        border-color: var(--accent) !important;
    }

    .round-entry {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(0, 0, 0, .5);
        border: 1px solid #0d0d0d;
        border-radius: 8px;
        padding: 10px 18px;
        font-size: .82rem;
    }

    .round-winner-me {
        border-left: 3px solid var(--accent);
    }

    .round-winner-opp {
        border-left: 3px solid var(--primary);
    }

    .round-draw {
        border-left: 3px solid #333;
    }
</style>

<script>
    const BATTLE_ID = {{ battle.id }};
    const STATE_URL = `/game/arena/${BATTLE_ID}/state`;
    const PLAY_URL = `/game/arena/${BATTLE_ID}/play`;
    const CRITERIA = ['horsepower', 'speed', 'acceleration', 'handling'];
    const CRIT_LABEL = {
        horsepower: '⚡ PUISSANCE',
        speed: '🏎 VITESSE MAX',
        acceleration: '🚀 ACCÉLÉRATION',
        handling: '🎯 MANIABILITÉ',
    };

    let lastRoundCount = 0;
    let gameEnded = false;
    let myPlayerNum = null;
    let renderedCards = null;

    async function fetchState() {
        try {
            const res = await fetch(STATE_URL);
            const data = await res.json();
            renderState(data);
            if (!gameEnded) setTimeout(fetchState, 2000);
        } catch {
            setTimeout(fetchState, 4000);
        }
    }

    function renderState(data) {
        myPlayerNum = data.myPlayerNumber;
        document.getElementById('scoreMe').textContent = data.roundsMe;
        document.getElementById('scoreOpp').textContent = data.roundsOpponent;
        document.getElementById('roundCount').textContent = `Round ${data.totalRounds}`;

        const nextCriterion = CRITERIA[data.totalRounds % CRITERIA.length];
        const banner = document.getElementById('criterionBanner');

        if (data.totalRounds > lastRoundCount && data.lastRound) {
            addRoundEntry(data.lastRound, data.myPlayerNumber);
            lastRoundCount = data.totalRounds;
            // Re-render la main avec le nouveau critère si toujours actif
            renderedCards = null;
        }

        if (data.status === 'waiting') {
            setStatus('⏳ En attente d\'un adversaire...', 'var(--primary)');
            show('waitingSection'); hide('handSection'); banner.style.display = 'none';
            return;
        }
        if (data.status === 'finished') {
            gameEnded = true;
            banner.style.display = 'none';
            showGameOver(data.iAmWinner, data.roundsMe, data.roundsOpponent);
            return;
        }

        banner.style.display = 'block';
        document.getElementById('criterionLabel').textContent = CRIT_LABEL[nextCriterion];

        hide('waitingSection'); show('handSection');

        if (data.iHavePlayed) {
            setStatus('✅ Carte jouée — En attente de l\'adversaire...', 'var(--primary)');
            setHandPlayed();
        } else {
            setStatus(`🎮 Jouez une carte !`, 'var(--accent)');
            renderHand(data.hand, nextCriterion);
        }
    }

    function show(id) { document.getElementById(id).style.display = 'block'; }
    function hide(id) { document.getElementById(id).style.display = 'none'; }
    function setStatus(msg, color) {
        const el = document.getElementById('statusText');
        el.innerHTML = msg; el.style.color = color || '#aaa';
    }

    function renderHand(cards, criterion) {
        const key = JSON.stringify(cards.map(c => c.id)) + criterion;
        if (renderedCards === key) return;
        renderedCards = key;

        const el = document.getElementById('hand');
        el.innerHTML = '';
        cards.forEach(card => {
            const div = document.createElement('div');
            div.className = `card-battle rarity-${card.rarity?.toLowerCase() ?? 'common'}`;

            const img = card.imagePath
                ? `<img src="${card.imagePath}" alt="${card.name}">`
                : `<div class="cb-placeholder"><i class="fa-solid fa-car-side"></i></div>`;

            div.innerHTML = `
            ${img}
            <div class="cb-info">
                <div class="cb-name">${card.name}</div>
                <div class="cb-stats">
                    <div class="cb-stat ${criterion === 'horsepower' ? 'active' : ''}">
                        <span class="cb-stat-lbl">CH</span>
                        <span class="cb-stat-val">${card.horsepower ?? '—'}</span>
                    </div>
                    <div class="cb-stat ${criterion === 'speed' ? 'active' : ''}">
                        <span class="cb-stat-lbl">km/h</span>
                        <span class="cb-stat-val">${card.speed ?? '—'}</span>
                    </div>
                    <div class="cb-stat ${criterion === 'acceleration' ? 'active' : ''}">
                        <span class="cb-stat-lbl">0-100</span>
                        <span class="cb-stat-val">${card.acceleration != null ? card.acceleration + 's' : '—'}</span>
                    </div>
                    <div class="cb-stat ${criterion === 'handling' ? 'active' : ''}">
                        <span class="cb-stat-lbl">mani.</span>
                        <span class="cb-stat-val">${card.handling ?? '—'}</span>
                    </div>
                </div>
            </div>
        `;
            div.onclick = () => playCard(card.id, div);
            el.appendChild(div);
        });
    }

    function setHandPlayed() {
        document.querySelectorAll('.card-battle').forEach(c => c.classList.add('played'));
    }

    async function playCard(cardId, el) {
        if (el.classList.contains('played')) return;
        el.classList.add('played');
        try {
            const res = await fetch(PLAY_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `card_id=${cardId}`,
            });
            const data = await res.json();
            if (!data.success) { el.classList.remove('played'); setStatus('⚠ ' + data.message, '#f00'); }
        } catch {
            el.classList.remove('played'); setStatus('⚠ Erreur réseau.', '#f00');
        }
    }

    function addRoundEntry(round, myNum) {
        const isP1 = (myNum === 1);
        const myName = isP1 ? round.p1Name : round.p2Name;
        const myVal = isP1 ? round.p1Val : round.p2Val;
        const opName = isP1 ? round.p2Name : round.p1Name;
        const opVal = isP1 ? round.p2Val : round.p1Val;
        const iWon = (round.winner === myNum);
        const isDraw = (round.winner === 0);

        const label = isDraw ? '⚖ ÉGALITÉ' : (iWon ? '✅ VICTOIRE' : '❌ DÉFAITE');
        const cls = isDraw ? 'round-draw' : (iWon ? 'round-winner-me' : 'round-winner-opp');
        const crit = CRIT_LABEL[round.criterion] ?? round.criterion?.toUpperCase() ?? '';

        const div = document.createElement('div');
        div.className = `round-entry ${cls}`;
        div.innerHTML = `
        <span style="min-width:110px; color:white;">${myName} <span style="color:var(--accent);">${myVal}</span></span>
        <div style="text-align:center;">
            <div style="color:#555; font-size:.75rem; text-transform:uppercase; letter-spacing:1px;">${label}</div>
            <div style="font-size:.6rem; color:#2a2a2a; letter-spacing:1px; margin-top:2px;">${crit}</div>
        </div>
        <span style="min-width:110px; text-align:right; color:white;">${opName} <span style="color:var(--primary);">${opVal}</span></span>
    `;
        document.getElementById('roundsList').prepend(div);
    }

    function showGameOver(iWon, me, opp) {
        document.getElementById('gameOverIcon').textContent = iWon ? '🏆' : '💀';
        document.getElementById('gameOverTitle').textContent = iWon ? 'VICTOIRE' : 'DÉFAITE';
        document.getElementById('gameOverTitle').style.color = iWon ? 'var(--accent)' : 'var(--primary)';
        document.getElementById('gameOverSub').textContent = iWon
            ? `${me} — ${opp} • +500 crédits !`
            : `${me} — ${opp} • Meilleure chance la prochaine fois.`;
        document.getElementById('gameOverOverlay').style.display = 'flex';
    }

    fetchState();
</script>

{% endblock %}