{% extends 'base.html.twig' %}

{% block title %}Inventaire - Redline Rivals{% endblock %}

{% block page_stylesheets %}
	<link rel="stylesheet" href="{{ asset('css/inventory.css') }}">
{% endblock %}

{% block body %}

<section class="hero" style="height: 40vh;">
    <h1 class="glitch-title">INVENTAIRE</h1>
    <p style="font-size: 1.3rem; letter-spacing: 3px; color: #ccc;">
        OUVREZ VOS BOOSTERS ET DÉCOUVREZ VOS CARTES
    </p>
</section>

<section class="section-bg-data">
    <div class="binary-line binary-line-1">01101001 01101110 01110110 01100101 01101110 01110100 01101111 01110010 01111001</div>
    <div class="binary-line binary-line-2">01100010 01101111 01101111 01110011 01110100 01100101 01110010 01110011</div>

    <div class="inventory-container">

        {% if boosters is empty %}
            <div class="empty-inventory">
                <i class="fa-solid fa-box-open empty-inventory-icon"></i>
                <h2>Aucun booster disponible</h2>
                <p>Achetez des boosters dans la boutique pour agrandir votre collection !</p>
                <a href="{{ path('app_game_shop') }}" class="btn-cyber">
                    <i class="fa-solid fa-shopping-cart"></i>
                    ALLER À LA BOUTIQUE
                </a>
            </div>
        {% else %}
            <div class="boosters-grid">
                {% for userBooster in boosters %}
                    {% set booster = userBooster.boosterType %}
                    <div class="booster-card"
                        data-user-booster-id="{{ userBooster.id }}"
                        style="border-color: {{ booster.color|default('var(--accent)') }}; --booster-color: {{ booster.color|default('var(--accent)') }};">

                        {% if userBooster.quantity > 1 %}
                            <div class="quantity-badge">×{{ userBooster.quantity }}</div>
                        {% endif %}

                        <div class="booster-image">
                            {% if booster.image %}
                                <img src="{{ asset('images/boosters/' ~ booster.image) }}" alt="{{ booster.name }}" class="booster-pack-img">
                            {% else %}
                                <i class="fa-solid fa-box-open booster-pack-icon"></i>
                            {% endif %}
                            <div class="booster-pulse"></div>
                        </div>

                        <div class="booster-info">
                            <h3 class="booster-name" style="color: {{ booster.color|default('var(--accent)') }}">
                                {{ booster.name }}
                            </h3>
                            <div class="booster-stats">
                                <div><i class="fa-solid fa-layer-group"></i> {{ booster.cardCount }} cartes</div>
                                <div class="legendary-chance"><i class="fa-solid fa-star"></i> {{ booster.legendaryChance }}% légendaire</div>
                            </div>
                            <button class="btn-cyber open-booster-btn" data-user-booster-id="{{ userBooster.id }}">
                                <i class="fa-solid fa-gift"></i> OUVRIR LE BOOSTER
                            </button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        <div class="nav-buttons">
            <a href="{{ path('app_game_shop') }}" class="btn-cyber">
                <i class="fa-solid fa-shopping-cart"></i> ACHETER DES BOOSTERS
            </a>
            <a href="{{ path('app_home') }}" class="btn-cyber">
                <i class="fa-solid fa-arrow-left"></i> RETOUR À L'ACCUEIL
            </a>
        </div>
    </div>
</section>

{# Modal #}
<div id="openBoosterModal" class="booster-modal">
    <div class="modal-overlay-bg"></div>
    <div class="modal-content">

        <div id="openingAnimation" class="opening-animation">
            <div class="booster-opening-wrap">
                <div class="booster-opening-icon"><i class="fa-solid fa-box-open"></i></div>
                <div class="ring ring-1"></div>
                <div class="ring ring-2"></div>
                <div class="ring ring-3"></div>
            </div>
            <h2 class="opening-text">OUVERTURE DU BOOSTER...</h2>
        </div>

        <div id="cardsReveal" class="cards-reveal">
            <h2 class="reveal-title">🎉 VOS NOUVELLES CARTES ! 🎉</h2>
            <div id="cardsContainer" class="cards-container"></div>
            <button id="closeModalBtn" class="btn-cyber close-modal-btn">
                <i class="fa-solid fa-check"></i> FERMER
            </button>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const openButtons    = document.querySelectorAll('.open-booster-btn');
    const modal          = document.getElementById('openBoosterModal');
    const openingAnim    = document.getElementById('openingAnimation');
    const cardsReveal    = document.getElementById('cardsReveal');
    const cardsContainer = document.getElementById('cardsContainer');
    const closeModalBtn  = document.getElementById('closeModalBtn');

    openButtons.forEach(btn => btn.addEventListener('click', function () {
        openBooster(this.dataset.userBoosterId);
    }));

    async function openBooster(id) {
        modal.classList.add('active');
        openingAnim.style.display = 'block';
        cardsReveal.style.display = 'none';
        cardsContainer.innerHTML  = '';

        try {
            const res  = await fetch(`/game/booster/open/${id}`, { method:'POST', headers:{'Content-Type':'application/json'} });
            const data = await res.json();

            if (data.success) {
                setTimeout(() => {
                    openingAnim.style.display = 'none';
                    cardsReveal.style.display = 'flex';

                    // Trier : communs en premier, légendaires en dernier
                    const order = { common:0, uncommon:1, rare:2, epic:3, legendary:4, mythic:5 };
                    const sorted = [...data.cards].sort((a,b) =>
                        (order[a.rarity?.toLowerCase()]??0) - (order[b.rarity?.toLowerCase()]??0)
                    );

                    sorted.forEach((card, i) => {
                        setTimeout(() => cardsContainer.appendChild(createCardElement(card)), 150 + i * 180);
                    });
                }, 1500);
            } else {
                throw new Error(data.message);
            }
        } catch (e) {
            alert(e.message || 'Erreur lors de l\'ouverture du booster');
            closeModal();
        }
    }

    const RARITY = {
        common   : { color:'#9e9e9e', dim:'rgba(158,158,158,.1)' },
        uncommon : { color:'#4CAF50', dim:'rgba(76,175,80,.1)' },
        rare     : { color:'#00f3ff', dim:'rgba(0,243,255,.1)' },
        epic     : { color:'#c353ff', dim:'rgba(195,83,255,.1)' },
        legendary: { color:'#ffd700', dim:'rgba(255,215,0,.15)' },
        mythic   : { color:'#ff0077', dim:'rgba(255,0,119,.15)' },
    };

    function createCardElement(card) {
        const rarity = card.rarity?.toLowerCase() ?? 'common';
        const rc     = RARITY[rarity] ?? RARITY.common;
        const isHigh = rarity === 'legendary' || rarity === 'mythic';

        const div = document.createElement('div');
        div.className = `card-reveal${isHigh ? ' is-'+rarity : ''}`;
        div.style.setProperty('--card-color',     rc.color);
        div.style.setProperty('--card-color-dim', rc.dim);

        const imageHtml = card.imagePath
            ? `<img src="/images/${card.imagePath}" alt="${card.name}" loading="lazy">`
            : `<div class="cr-image-placeholder"><i class="fa-solid fa-car-side"></i></div>`;

        div.innerHTML = `
            <div class="cr-image-wrap">
                ${imageHtml}
                <div class="cr-image-overlay"></div>
                <div class="cr-scanline"></div>
                <div class="cr-rarity-badge">${card.rarity}</div>
                ${card.isNew ? '<div class="cr-new-badge">NEW</div>' : ''}
            </div>
            <div class="cr-info">
                <p class="cr-name">${card.name}</p>
                <p class="cr-brand">${card.brand ?? '—'}</p>
                <div class="cr-divider"></div>
                <div class="cr-stats">
                    <div class="cr-stat">
                        <span class="cr-stat-label">Chevaux</span>
                        <span class="cr-stat-value">${card.horsepower}</span>
                    </div>
                    <div class="cr-stat">
                        <span class="cr-stat-label">Rareté</span>
                        <span class="cr-stat-value small">${card.rarity?.toUpperCase()}</span>
                    </div>
                </div>
            </div>
        `;

        // Glow persistant pour les hautes raretés
        if (isHigh) {
            div.addEventListener('animationend', () => {
                div.style.boxShadow = `0 0 20px ${rc.dim}, 0 0 40px ${rc.dim}`;
            }, { once: true });
        }

        return div;
    }

    closeModalBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', e => {
        if (e.target === modal || e.target.classList.contains('modal-overlay-bg')) {
            if (cardsReveal.style.display === 'flex') closeModal();
        }
    });

    function closeModal() {
        modal.classList.remove('active');
        setTimeout(() => location.reload(), 300);
    }
});
</script>
{% endblock %}
