{% extends 'base.html.twig' %}

{% block title %}Boutique de Boosters - Chrome Nexus{% endblock %}

{% block page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/shop.css') }}">
{% endblock %}

{% block body %}

<section class="hero" style="height: 50vh;">
    <h1 class="glitch-title">BOUTIQUE</h1>
    <p style="font-size: 1.3rem; letter-spacing: 3px; color: #ccc;">
        ACHETEZ DES BOOSTERS ET AGRANDISSEZ VOTRE COLLECTION
    </p>
    <div style="margin-top: 20px;">
        <span style="font-size: 1.5rem; color: var(--gold);">
            <i class="fa-solid fa-coins"></i> {{ app.user.credits }} CRÉDITS
        </span>
        <span style="margin-left: 30px; font-size: 1.3rem; color: var(--accent);">
            <i class="fa-solid fa-box"></i> {{ userBoostersCount }} BOOSTER{% if userBoostersCount > 1 %}S{% endif %}
        </span>
    </div>
</section>

<section class="section-bg-data" style="background: linear-gradient(180deg, #0a0a0a 0%, #1a1a2e 100%); position: relative;">
    <div class="binary-line binary-line-1">01110011 01101000 01101111 01110000 00100000 01100010 01101111 01101111 01110011 01110100 01100101 01110010 01110011</div>
    <div class="binary-line binary-line-2">01100011 01111001 01100010 01100101 01110010 00100000 01110000 01100001 01100011 01101011 01110011</div>
    
    <div style="max-width: 1400px; margin: 0 auto; padding: 60px 20px; position: relative; z-index: 1;">
        
        {% if boosters is empty %}
            <div style="background: rgba(0,0,0,0.7); border: 2px solid var(--accent); border-radius: 15px; padding: 60px; text-align: center;">
                <i class="fa-solid fa-box-open" style="font-size: 5rem; color: var(--accent); margin-bottom: 20px; opacity: 0.5;"></i>
                <h2 style="color: var(--accent); margin-bottom: 15px;">Aucun booster disponible</h2>
                <p style="color: #aaa;">Les boosters seront bientôt disponibles à l'achat !</p>
            </div>
        {% else %}
            <!-- Grille de boosters -->
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 35px; margin-bottom: 60px;">
                
                {% for booster in boosters %}
                <div class="booster-card" 
                     data-booster-id="{{ booster.id }}"
                     data-rarity="{{ booster.rarity|lower }}"
                     style="background: linear-gradient(135deg, rgba(10,10,30,0.95) 0%, rgba(20,20,40,0.9) 100%); 
                            border: 2px solid rgba(0,255,255,0.3); 
                            border-radius: 20px; 
                            overflow: hidden; 
                            transition: all 0.3s ease; 
                            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
                            position: relative;">
                    
                    <!-- Badge de rareté -->
                    <div class="rarity-badge rarity-{{ booster.rarity|lower }}" 
                         style="position: absolute; 
                                top: 20px; 
                                right: 20px; 
                                z-index: 10; 
                                padding: 8px 20px; 
                                border-radius: 20px; 
                                font-size: 0.85rem; 
                                font-weight: bold; 
                                text-transform: uppercase; 
                                letter-spacing: 1px;">
                        {{ booster.rarity|upper }}
                    </div>
                    
                    <!-- Image du booster -->
                    <div style="position: relative; 
                                height: 250px; 
                                background: linear-gradient(135deg, rgba(0,255,255,0.1) 0%, rgba(255,0,255,0.1) 100%); 
                                display: flex; 
                                align-items: center; 
                                justify-content: center;
                                overflow: hidden;
                                border-bottom: 2px solid rgba(0,255,255,0.3);">
                        <i class="fa-solid fa-box-open booster-icon booster-icon-{{ booster.rarity|lower }}"></i>
                        
                        <!-- Effet de brillance -->
                        <div class="booster-shine" 
                             style="position: absolute; 
                                    inset: 0; 
                                    background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%); 
                                    transform: translateX(-100%); 
                                    animation: shine 3s ease-in-out infinite;"></div>
                    </div>
                    
                    <!-- Informations -->
                    <div style="padding: 30px;">
                        <h3 style="color: var(--accent); 
                                   font-size: 1.6rem; 
                                   margin-bottom: 15px; 
                                   text-transform: uppercase; 
                                   letter-spacing: 2px;
                                   text-shadow: 0 0 10px rgba(0,255,255,0.5);">
                            {{ booster.name }}
                        </h3>
                        
                        <p style="color: #aaa; 
                                  margin-bottom: 25px; 
                                  line-height: 1.6; 
                                  font-size: 0.95rem;">
                            {{ booster.description }}
                        </p>
                        
                        <!-- Stats -->
                        <div style="display: grid; 
                                    grid-template-columns: 1fr 1fr; 
                                    gap: 15px; 
                                    margin-bottom: 25px;">
                            <div style="background: rgba(0,0,0,0.4); 
                                        border: 1px solid rgba(0,255,255,0.3); 
                                        border-radius: 10px; 
                                        padding: 15px; 
                                        text-align: center;">
                                <i class="fa-solid fa-cards" style="font-size: 1.5rem; color: var(--accent); margin-bottom: 8px; display: block;"></i>
                                <div style="font-size: 1.3rem; font-weight: bold; color: #fff;">{{ booster.cardCount }}</div>
                                <div style="font-size: 0.85rem; color: #888; text-transform: uppercase; letter-spacing: 1px;">cartes</div>
                            </div>
                            <div style="background: rgba(0,0,0,0.4); 
                                        border: 1px solid rgba(255,215,0,0.3); 
                                        border-radius: 10px; 
                                        padding: 15px; 
                                        text-align: center;">
                                <i class="fa-solid fa-star" style="font-size: 1.5rem; color: var(--gold); margin-bottom: 8px; display: block;"></i>
                                <div style="font-size: 1.3rem; font-weight: bold; color: var(--gold);">{{ booster.legendaryChance }}%</div>
                                <div style="font-size: 0.85rem; color: #888; text-transform: uppercase; letter-spacing: 1px;">légendaire</div>
                            </div>
                        </div>
                        
                        <!-- Prix et achat -->
                        <div style="display: flex; 
                                    align-items: center; 
                                    justify-content: space-between; 
                                    gap: 15px; 
                                    padding-top: 20px; 
                                    border-top: 1px solid rgba(0,255,255,0.2);">
                            <div style="display: flex; 
                                        align-items: center; 
                                        gap: 10px; 
                                        font-size: 1.5rem; 
                                        font-weight: bold; 
                                        color: var(--gold);">
                                <i class="fa-solid fa-coins"></i> 
                                {{ booster.price }}
                            </div>
                            <button type="button" 
                                    class="btn-cyber buy-booster-btn {% if app.user.credits < booster.price %}btn-disabled{% endif %}" 
                                    data-booster-id="{{ booster.id }}"
                                    data-booster-price="{{ booster.price }}"
                                    style="flex: 1; 
                                           padding: 15px 25px; 
                                           font-size: 1rem; 
                                           font-weight: bold; 
                                           letter-spacing: 2px;"
                                    {% if app.user.credits < booster.price %}disabled{% endif %}>
                                {% if app.user.credits < booster.price %}
                                    <i class="fa-solid fa-lock"></i> CRÉDITS INSUFFISANTS
                                {% else %}
                                    <i class="fa-solid fa-shopping-cart"></i> ACHETER
                                {% endif %}
                            </button>
                        </div>
                    </div>
                </div>
                {% endfor %}
                
            </div>
        {% endif %}
        
        <!-- Boutons d'action -->
        <div style="display: flex; justify-content: center; gap: 30px; flex-wrap: wrap;">
            {% if userBoostersCount > 0 %}
            <a href="{{ path('app_game_inventory') }}" 
               class="btn-cyber" 
               style="padding: 20px 40px; 
                      font-size: 1.2rem; 
                      background: linear-gradient(135deg, rgba(0,255,255,0.2), rgba(0,200,200,0.3)); 
                      border: 2px solid var(--accent); 
                      box-shadow: 0 0 30px rgba(0,255,255,0.4);">
                <i class="fa-solid fa-box-open"></i> 
                OUVRIR MES BOOSTERS ({{ userBoostersCount }})
            </a>
            {% endif %}
            
            <a href="{{ path('app_home') }}" 
               class="btn-cyber" 
               style="padding: 20px 40px; 
                      font-size: 1.2rem; 
                      background: rgba(0,0,0,0.5); 
                      border: 2px solid rgba(255,255,255,0.3);">
                <i class="fa-solid fa-arrow-left"></i> RETOUR À L'ACCUEIL
            </a>
        </div>
    </div>
</section>

<style>
@keyframes shine {
    0% { transform: translateX(-100%); }
    50%, 100% { transform: translateX(200%); }
}

@keyframes pulse-gold {
    0%, 100% { box-shadow: 0 0 20px rgba(251, 191, 36, 0.6); }
    50% { box-shadow: 0 0 30px rgba(251, 191, 36, 0.9), 0 0 40px rgba(251, 191, 36, 0.6); }
}

/* Styles des badges de rareté */
.rarity-badge.rarity-standard {
    background: linear-gradient(135deg, #4a5568, #718096);
    border: 1px solid #a0aec0;
    color: #fff;
}

.rarity-badge.rarity-premium {
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
    border: 1px solid #c084fc;
    color: #fff;
}

.rarity-badge.rarity-ultra {
    background: linear-gradient(135deg, #d946ef, #f472b6);
    border: 1px solid #f472b6;
    color: #fff;
}

.rarity-badge.rarity-legendary {
    background: linear-gradient(135deg, #ca8a04, #fbbf24);
    border: 1px solid #fcd34d;
    color: #fff;
}

/* Styles des icônes de booster */
.booster-icon {
    font-size: 8rem;
    color: var(--accent);
    filter: drop-shadow(0 0 10px var(--accent));
}

.booster-icon-standard {
    color: #a0aec0 !important;
    filter: drop-shadow(0 0 10px #a0aec0) !important;
}

.booster-icon-premium {
    color: #a78bfa !important;
    filter: drop-shadow(0 0 15px #a78bfa) !important;
}

.booster-icon-ultra {
    color: #f472b6 !important;
    filter: drop-shadow(0 0 15px #f472b6) !important;
}

.booster-icon-legendary {
    color: var(--gold) !important;
    filter: drop-shadow(0 0 20px var(--gold)) !important;
}

.booster-card {
    cursor: pointer;
}

.booster-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--accent) !important;
    box-shadow: 0 20px 50px rgba(0,255,255,0.4), 0 0 30px rgba(0,255,255,0.2) !important;
}

.btn-disabled {
    opacity: 0.5 !important;
    cursor: not-allowed !important;
}

.cyber-notification {
    position: fixed;
    top: 20px;
    right: 20px;
    padding: 20px 30px;
    border-radius: 10px;
    font-weight: bold;
    z-index: 10000;
    animation: slideIn 0.3s ease-out;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.cyber-notification-success {
    background: linear-gradient(135deg, rgba(0,200,0,0.9), rgba(0,255,0,0.8));
    border: 2px solid #00ff00;
    color: #000;
}

.cyber-notification-error {
    background: linear-gradient(135deg, rgba(200,0,0,0.9), rgba(255,0,0,0.8));
    border: 2px solid #ff0000;
    color: #fff;
}

@keyframes slideIn {
    from {
        transform: translateX(400px);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

@keyframes slideOut {
    from {
        transform: translateX(0);
        opacity: 1;
    }
    to {
        transform: translateX(400px);
        opacity: 0;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM chargé');
    const buyButtons = document.querySelectorAll('.buy-booster-btn');
    console.log('Nombre de boutons trouvés:', buyButtons.length);
    
    buyButtons.forEach(button => {
        console.log('Ajout listener sur bouton:', button.dataset.boosterId);
        button.addEventListener('click', async function(e) {
            e.preventDefault();
            console.log('Click détecté sur bouton:', this.dataset.boosterId);
            
            if (this.disabled) {
                console.log('Bouton désactivé');
                return;
            }
            
            const boosterId = this.dataset.boosterId;
            const boosterPrice = parseInt(this.dataset.boosterPrice);
            console.log('Achat booster ID:', boosterId, 'Prix:', boosterPrice);
            
            // Désactiver le bouton pendant la requête
            this.disabled = true;
            const originalContent = this.innerHTML;
            this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> TRAITEMENT...';
            
            try {
                console.log('Envoi requête vers:', `/game/shop/buy/${boosterId}`);
                const response = await fetch(`/game/shop/buy/${boosterId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({})
                });
                
                console.log('Réponse reçue, status:', response.status);
                const data = await response.json();
                console.log('Données JSON:', data);
                
                if (data.success) {
                    // Animation de succès
                    this.innerHTML = '<i class="fa-solid fa-check"></i> ACHETÉ !';
                    this.style.background = 'linear-gradient(135deg, #00ff00, #00cc00)';
                    this.style.borderColor = '#00ff00';
                    
                    // Mettre à jour les crédits affichés
                    updateCreditsDisplay(data.credits);
                    
                    // Mettre à jour le compteur de boosters
                    updateBoostersDisplay(data.boostersCount);
                    
                    // Afficher notification
                    showNotification('🎉 Booster acheté avec succès !', 'success');
                    
                    // Recharger après 1.5 secondes
                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    throw new Error(data.message || 'Erreur inconnue');
                }
            } catch (error) {
                console.error('Erreur complète:', error);
                this.innerHTML = '<i class="fa-solid fa-times"></i> ERREUR';
                this.style.background = 'linear-gradient(135deg, #ff0000, #cc0000)';
                this.style.borderColor = '#ff0000';
                showNotification(error.message || 'Erreur lors de l\'achat', 'error');
                
                // Réactiver après 2 secondes
                setTimeout(() => {
                    this.disabled = false;
                    this.style.background = '';
                    this.style.borderColor = '';
                    this.innerHTML = originalContent;
                }, 2000);
            }
        });
    });
});

function updateCreditsDisplay(credits) {
    const creditsElement = document.querySelector('.fa-coins').parentElement;
    creditsElement.innerHTML = `<i class="fa-solid fa-coins"></i> ${credits} CRÉDITS`;
}

function updateBoostersDisplay(count) {
    const boostersElement = document.querySelector('.fa-box').parentElement;
    const plural = count > 1 ? 'S' : '';
    boostersElement.innerHTML = `<i class="fa-solid fa-box"></i> ${count} BOOSTER${plural}`;
}

function showNotification(message, type = 'info') {
    // Supprimer les anciennes notifications
    document.querySelectorAll('.cyber-notification').forEach(n => n.remove());
    
    // Créer une notification
    const notification = document.createElement('div');
    notification.classList.add('cyber-notification', `cyber-notification-${type}`);
    notification.textContent = message;
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease-in';
        setTimeout(() => notification.remove(), 300);
    }, 3000);
}
</script>

{% endblock %}
