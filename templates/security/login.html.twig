{% extends 'base.html.twig' %}

{% block title %}LOGIN // REDLINE RIVALS{% endblock %}

{% block page_stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
{# On réutilise le conteneur centré avec fond scan #}
<div class="section-bg-scan flex-center-screen">

    <div class="cyber-auth-card">
        {# Décorations futuristes aux coins #}
        <div class="card-decoration top-left"></div>
        <div class="card-decoration bottom-right"></div>

        <h1 class="section-title" style="margin-bottom: 30px; font-size: 2rem;">
            ACCÈS PILOTE
        </h1>

        <form method="post" class="cyber-form">
            
            {# Affichage des erreurs de connexion #}
            {% if error %}
                <div class="cyber-alert" style="margin-bottom: 20px;">
                    <i class="fas fa-exclamation-triangle"></i> 
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {# Message si l'utilisateur est déjà connecté #}
            {% if app.user %}
                <div class="cyber-alert" style="color: var(--accent); border-color: var(--accent);">
                    Déjà connecté en tant que <span style="font-weight:bold; color:white;">{{ app.user.userIdentifier }}</span>.
                    <br>
                    <a href="{{ path('app_logout') }}" class="link-accent" style="font-size: 0.9rem;">Déconnexion immédiate</a>
                </div>
            {% endif %}

            <div class="form-group">
                <label for="inputEmail" class="cyber-label">Identifiant (Email)</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="cyber-input" autocomplete="email" placeholder="pilote@redline.com" required autofocus>
            </div>

            <div class="form-group">
                <label for="inputPassword" class="cyber-label">Code d'accès</label>
                <input type="password" name="password" id="inputPassword" class="cyber-input" autocomplete="current-password" placeholder="••••••••" required>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div class="form-group checkbox-group">
                <label class="cyber-label-check" style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" name="_remember_me" class="cyber-checkbox">
                    Rester connecté au réseau
                </label>
            </div>

            <button class="btn-cyber btn-primary w-100" type="submit">
                ÉTABLIR LA LIAISON
            </button>

            <div class="auth-footer">
                Pas encore de licence ? <a href="{{ path('app_register') }}" class="link-accent">Rejoindre les rangs</a>
            </div>
            
        </form>
    </div>
</div>
{% endblock %}